# Roamie — environment variables (copy to .env, never commit .env)

# ── Supabase (client-safe VITE_ prefix) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Sign in with Apple（Supabase Provider 已設定 + iOS 原生登入）
VITE_APPLE_SIGN_IN_ENABLED=true

# OAuth redirect（選用 — 正式 Web 網域確定後再填，勿寫死在程式碼）
# iOS TestFlight 固定使用 roamie://auth/callback（見 src/constants/auth-redirect.ts）
# Supabase Redirect URLs 建議至少加入：
#   roamie://auth/callback
#   http://localhost:8080/auth/callback
# AI /api/roamie（bundled iOS 必填；勿用 localhost，TestFlight 請用正式 HTTPS）
# VITE_APP_ORIGIN=https://roamie.tw
# 自訂網域尚未就緒時可暫用 workers.dev，例如：
# VITE_APP_ORIGIN=https://roamie.<account-subdomain>.workers.dev

# ── Server-only (synced to .dev.vars via npm run sync:env) ──
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
OPENAI_API_KEY=
# OpenWeather（首頁天氣、穿搭建議、AI 行程；server 會讀取下列任一 key）
OPENWEATHER_API_KEY=
EXPO_PUBLIC_OPENWEATHER_API_KEY=
# VITE_OPENWEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=
# Server 專用（探索 nearby / 規劃搜尋 REST）— 勿設「iOS App」限制，否則 403 API_KEY_IOS_APP_BLOCKED
# 建議：無應用程式限制 + API 限制僅 Places/Geocoding；或 IP 限制（部署主機）
GOOGLE_PLACES_SERVER_API_KEY=
# Expo / React Native 地圖與 Routes（client / Maps JS 優先讀此項）
# Google Cloud 需啟用：Maps JavaScript API、Places API (New)、Geocoding API、Routes API，並開啟帳單
# iOS Capacitor WebView：EXPO_PUBLIC 金鑰可設 iOS App + bundle id com.shuode.roamie
#   或「網站限制」加 capacitor://localhost/*（勿只填 localhost:8080）
# 若 Xcode 出現 BillingNotEnabledMapError = 必須在 GCP 專案啟用帳單（Billing）
# 若地圖出現 For development purposes only = 帳單未啟用或金鑰限制不符
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
# 真機 bundled 模式：地點圖 proxy 需正式網域（選填）
# VITE_APP_ORIGIN=https://roamie.tw
# 自訂網域尚未就緒時可暫用 workers.dev，例如：
# VITE_APP_ORIGIN=https://roamie.<account-subdomain>.workers.dev
# Web Vite fallback
# VITE_GOOGLE_MAPS_API_KEY=

# ── Analytics (optional) ──
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://app.posthog.com
# VITE_MIXPANEL_TOKEN=

# ── Subscriptions — RevenueCat public SDK keys ──
# VITE_REVENUECAT_APPLE_KEY=
# VITE_REVENUECAT_GOOGLE_KEY=
# Billing switch (default off; enable only when launching real payments)
# VITE_BILLING_ENABLED=0

# Developer / QA (dev builds only)
# VITE_ROAMIE_DEVELOPER=1
# VITE_DEVELOPER_EMAILS=you@example.com
# QA 測試登入（登入頁「測試登入」、DEV TEST USER 標籤；正式 App Store 勿開）
# VITE_ROAMIE_QA=1
# Worker 端啟用 /api/qa-auth（與 VITE_ROAMIE_QA 搭配；正式上架可設 0 或刪除）
# ROAMIE_QA_AUTH_ENABLED=1
# ROAMIE_QA_AUTH_SECRET=optional-long-random-string
# iOS Simulator dev (Vite must be running):
CAPACITOR_DEV_SERVER_URL=http://localhost:8080
# 開發版 iOS Simulator 會自動把舊金山預設 GPS 改為台灣測試點；可自訂：
# VITE_CAPACITOR_DEV_LOCATION_LAT=25.033
# VITE_CAPACITOR_DEV_LOCATION_LNG=121.565
# 若要保留 Simulator 真實舊金山座標（除錯用）：
# VITE_LOCATION_USE_SIMULATOR_GPS=1
# Physical device dev — use Vite Network URL instead:
# CAPACITOR_DEV_SERVER_URL=http://192.168.0.60:8080
# Production / TestFlight (HTTPS deployed app):
# CAPACITOR_SERVER_URL=https://your-roamie-domain.com
# VITE_AFFILIATE_BOOKING_AID=
# VITE_AFFILIATE_AGODA_AID=
# VITE_AFFILIATE_KLOOK_AID=
