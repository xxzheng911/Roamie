# Roamie — environment variables (copy to .env, never commit .env)

# ── Supabase (client-safe VITE_ prefix) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Sign in with Apple (requires Apple Developer + Supabase Apple provider)
# VITE_APPLE_SIGN_IN_ENABLED=true

# ── Server-only (synced to .dev.vars via npm run sync:env) ──
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
OPENAI_API_KEY=
GOOGLE_MAPS_API_KEY=

# Optional client maps key — prefer server proxy in production
# VITE_GOOGLE_MAPS_API_KEY=

# ── Analytics (optional) ──
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://app.posthog.com
# VITE_MIXPANEL_TOKEN=

# ── Subscriptions — RevenueCat public SDK keys ──
# VITE_REVENUECAT_APPLE_KEY=
# VITE_REVENUECAT_GOOGLE_KEY=

# ── Native shell (Capacitor) ──
# iOS Simulator dev (Vite must be running):
CAPACITOR_DEV_SERVER_URL=http://localhost:8080
# Physical device dev — use Vite Network URL instead:
# CAPACITOR_DEV_SERVER_URL=http://192.168.0.60:8080
# Production / TestFlight (HTTPS deployed app):
# CAPACITOR_SERVER_URL=https://your-roamie-domain.com
# VITE_AFFILIATE_BOOKING_AID=
# VITE_AFFILIATE_AGODA_AID=
# VITE_AFFILIATE_KLOOK_AID=
